# proxsyno app environment — example.
#
# install-app.sh writes the real file to /etc/proxsyno/proxsyno.env and
# generates a strong PROXSYNO_JWT_SECRET for you. Copy this only if you are
# setting things up by hand.
#
#   cp deploy/proxsyno.env.example /etc/proxsyno/proxsyno.env
#   chmod 600 /etc/proxsyno/proxsyno.env
#   sed -i "s|CHANGE_ME_TO_A_LONG_RANDOM_STRING|$(openssl rand -hex 32)|" /etc/proxsyno/proxsyno.env

# Secret used to sign session JWTs. MUST be long and random. Never commit it.
# Generate one with: openssl rand -hex 32
PROXSYNO_JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING

# HTTP port the backend listens on (it also serves the built frontend).
PORT=8800

# Only users in this Unix group may log in (PAM auth + group check).
ADMIN_GROUP=sudo

# Jail root for the file browser. All file ops are confined inside this path.
FILES_ROOT=/mnt

# Run mode. Leave as production for the systemd service (serves app/web/dist).
NODE_ENV=production
