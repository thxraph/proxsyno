# node deps & build output (package-lock.json IS committed)
node_modules/
dist/

# downloaded packages / build artifacts
*.deb
*.tmp
tmp/
# editor noise
*.swp
.DS_Store

# local secrets — real env files & key material are NEVER committed
# (the *.example templates, which hold only placeholders, ARE tracked)
.env
.env.*
!.env.example
*.pem
*.key

# local planning notes
docs/fable_plan.md
