# proxsyno backend configuration
# Copy to .env for local dev, or install as /etc/proxsyno/proxsyno.env in production.

# REQUIRED: secret used to sign session JWTs. Generate with: openssl rand -hex 32
# The server refuses to start in production without a strong (>=16 char) secret.
PROXSYNO_JWT_SECRET=change-me-to-a-long-random-string

# Port the HTTP/WS server listens on.
PORT=8800

# Bind address. Use 127.0.0.1 to keep behind a reverse proxy; 0.0.0.0 to expose.
HOST=0.0.0.0

# Built-in TLS. When true, the server listens HTTPS on PORT using the cert/key
# below (install-app.sh --tls generates a self-signed pair). Auto-enables the
# Secure session cookie. Leave false when terminating TLS at a reverse proxy
# (set COOKIE_SECURE=true there instead).
TLS_ENABLED=false
TLS_CERT=/etc/proxsyno/tls/cert.pem
TLS_KEY=/etc/proxsyno/tls/key.pem
# Optional: a plain-HTTP port that 301-redirects to HTTPS (0 = disabled).
HTTP_REDIRECT_PORT=0

# Unix group that grants admin (login) access. Only members may log in.
ADMIN_GROUP=sudo

# Root directory the jailed file browser is confined to.
FILES_ROOT=/mnt

# Lifetime of a session in seconds (default 12h).
SESSION_TTL_SEC=43200

# Node environment: "development" or "production".
# In production the server serves ../web/dist as the SPA at "/".
NODE_ENV=development

# PAM service name used for authentication (file under /etc/pam.d/).
PAM_SERVICE=login

# Path to the Samba config file managed by proxsyno.
SMB_CONF=/etc/samba/smb.conf

# Path to the NFS exports file managed by proxsyno.
NFS_EXPORTS=/etc/exports

# Max upload size in bytes (default 5 GiB).
MAX_UPLOAD_BYTES=5368709120
